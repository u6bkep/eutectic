# The multiprobe part library (library package `poc`) — the data form of the old
# examples/poc_multiprobe.rs build_lib(). Footprints are KiCad's official library
# files; roles come from a symbol join (RP2350A) or a hand role map (jellybeans).

# U1: RP2350A QFN-60 — authoritative symbol + footprint, joined cleanly. The six
# IOVDD and three DVDD pads keep their shared functional names, so connecting
# "IOVDD" fans out to all six pads.
part RP2350A footprint=RP2350A_QFN-60.kicad_mod symbol=MCU_RaspberryPi.kicad_sym:RP2350A

# J1..J10: JST-SH 3-pin (pads 1,2,3,MP) — passive connector, no roles.
part JST_SH footprint=JST_SH_3pin_Horizontal.kicad_mod

# U2: QSPI flash W25Q (SOIC-8). 1=/CS 2=IO1(DO) 3=IO2(/WP) 4=GND 5=IO0(DI)
# 6=CLK 7=IO3(/HOLD) 8=VCC.
part W25Q footprint=Flash_SOIC-8.kicad_mod {
  role 1 CS_N input
  role 2 IO1 bidir
  role 3 IO2 bidir
  role 4 GND passive
  role 5 IO0 bidir
  role 6 CLK input
  role 7 IO3 bidir
  role 8 VCC power_in
}

# Y1: 12 MHz crystal, 3225 4-pad. 1/3 = terminals, 2/4 = case GND.
part XTAL footprint=Crystal_3225.kicad_mod {
  role 1 X1 passive
  role 2 GNDa passive
  role 3 X2 passive
  role 4 GNDb passive
}

# U3: 3.3 V LDO/reg (AP2112K-3.3, SOT-23-5): 1=VIN 2=GND 3=EN 4=NC 5=VOUT.
part REG footprint=Regulator_SOT-23-5.kicad_mod {
  role 1 VIN power_in
  role 2 GND passive
  role 3 EN input
  role 4 NC passive
  role 5 VOUT power_out
}

# J11: USB-C receptacle (USB 2.0). The four VBUS pads, four GND pads, and the two
# DP / two DM pads share a name each, so connecting "VBUS"/"GND"/"DP"/"DM" fans
# out to every physical pad.
part USBC footprint=USB_C_Receptacle.kicad_mod {
  role A1 GND passive
  role A4 VBUS power_in
  role A5 CC1 passive
  role A6 DP bidir
  role A7 DM bidir
  role A8 SBU1 passive
  role A9 VBUS power_in
  role A12 GND passive
  role B1 GND passive
  role B4 VBUS power_in
  role B5 CC2 passive
  role B6 DP bidir
  role B7 DM bidir
  role B8 SBU2 passive
  role B9 VBUS power_in
  role B12 GND passive
  role SH SHIELD passive
}

# L1: core-buck inductor 3.3 uH (2020). R/C/inductor passives keep pads "1","2".
part IND footprint=Inductor_2020.kicad_mod
part R footprint=R_0402.kicad_mod
part C footprint=C_0402.kicad_mod

# SW1 BOOTSEL, SW2 RUN — 2-terminal tactile.
part BTN footprint=Button_EVQP7A.kicad_mod

# D1: WS2812B-2020 status LED. 1=VDD 2=DOUT 3=GND 4=DIN.
part LED footprint=LED_WS2812B.kicad_mod {
  role 1 VDD power_in
  role 2 DOUT output
  role 3 GND passive
  role 4 DIN input
}
